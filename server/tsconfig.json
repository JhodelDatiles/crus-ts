{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": { // CHANGE THE FOLLOWING THAT HAS "CHANGE THIS"
    // File Layout
    "rootDir": "./src", // CHANGE THIS
    "outDir": "./dist", // CHANGE THIS

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext", // CHANGE THIS
    "moduleResolution": "nodenext", // CHANGE THIS
    "target": "es2022", // CHANGE THIS 
    "types": [],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true, // CHANGE THIS 
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true, // CHANGE THIS 
  }
}
